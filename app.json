{
  "expo": {
    "name": "kidcoin-v3",
    "slug": "kidcoin-v3",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "kidcoinv3",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.kidcoin.v3",
      "versionCode": 2,
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./src/assets/branding/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "@react-native-google-signin/google-signin",
      [
        "expo-image-picker",
        {
          "photosPermission": "KidCoin needs access to your photos so you can attach task evidence.",
          "cameraPermission": "KidCoin needs access to your camera so you can take task evidence photos.",
          "microphonePermission": false
        }
      ],
      "./plugins/withCropActivityTheme"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "firebase": {
        "apiKey": "AIzaSyDRqvK3_CxRKBcnKLyQB_RNnIDW4wSChoM",
        "authDomain": "kidcoin-free-2026-v2.firebaseapp.com",
        "projectId": "kidcoin-free-2026-v2",
        "storageBucket": "kidcoin-free-2026-v2.firebasestorage.app",
        "messagingSenderId": "27298096985",
        "appId": "1:27298096985:android:2d398174550167a70fce48"
      },
      "google": {
        "iosClientId": "",
        "androidClientId": "27298096985-rg4nehcs0rftmjgjgi5uvt46ffbq4pcr.apps.googleusercontent.com",
        "webClientId": "27298096985-3o4bqmfs1ccdn3kr7gtfr0lurfois2og.apps.googleusercontent.com"
      }
    },
    "splash": {
      "image": "./src/assets/branding/splash-icon.png",
      "backgroundColor": "#ffffff",
      "dark": {
        "backgroundColor": "#000000"
      }
    }
  }
}
